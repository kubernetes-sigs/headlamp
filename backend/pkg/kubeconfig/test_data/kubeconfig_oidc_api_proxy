apiVersion: v1
clusters:
- cluster:
    server: https://127.0.0.1:6443
  name: api-proxy-test-cluster
contexts:
- context:
    cluster: api-proxy-test-cluster
    user: api-proxy-test-user
  name: api-proxy-test-context
current-context: api-proxy-test-context
kind: Config
preferences: {}
users:
- name: api-proxy-test-user
  user:
    auth-provider:
      config:
        client-id: "test-client-id"
        client-secret: "test-client-secret"
        idp-issuer-url: "https://oidc.example.com"
        scope: "profile,email"
        api-proxy: "https://api-proxy.example.com/kubernetes"
        api-proxy-ca-data: ""
        api-proxy-skip-tls-verify: "false"
      name: oidc
