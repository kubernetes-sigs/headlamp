{
  "mcpServers": {
    "kubernetes": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "kubernetes-mcp-server@latest", "--read-only"]
    },
    "helm": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-server-kubernetes@latest"],
      "env": {
        "ALLOWED_TOOLS": "install_helm_chart,upgrade_helm_chart"
      }
    },
    "chrome-devtools": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "chrome-devtools-mcp@latest", "--browser-url=http://127.0.0.1:9222"]
    }
  }
}
